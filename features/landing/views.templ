// SCOPE:feature - REMOVE by deleting features/landing/ + the
// call site in router/router.go. The landing page is a marketing
// shell: logo + about text + "Access demo site" CTA. It does NOT
// call the database, does NOT authenticate the user (guests and
// signed-in users see the same hero), and registers only the
// GET / route.
//
// Content policy: the about text is sourced from the project's
// own README so the page mirrors the repo, not an LLM summary.
// Source lines (README.md): the tagline block (~7-9) carries the
// project positioning; the rest of the README is not surfaced.
package landing

import (
	"github.com/calionauta/gogogo-fullstack-template/features/auth"
	"github.com/calionauta/gogogo-fullstack-template/internal/components"
)

// Index renders the landing page. userEmail is empty for guests
// (Sign in CTA shows) and the authed email for signed-in users.
// buildLabel/buildCommit are surfaced on the version badge so the
// landing page matches the navbar's build feedback.
templ Index(userEmail string, buildLabel string, buildCommit string) {
	<!DOCTYPE html>
	<html lang="en" data-theme="light">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>gogogo-fullstack-template</title>
			<link rel="stylesheet" href="/static/app.min.css"/>
			<link rel="stylesheet" href="/static/app.css"/>
			@auth.ThemeHead()
			<script defer type="module" src="/static/theme.js"></script>
			<script src="/static/iconify-icon.min.js"></script>
			<style>
				/* Hero layout: narrow column on desktop, full width on
				   mobile. The visual hierarchy is logo → about → CTA,
				   matching the README ordering. */
				.landing-hero {
					min-height: calc(100vh - 4rem);
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					padding: 2rem 1rem;
				}
				.landing-card {
					max-width: 44rem;
					width: 100%;
				}
				.landing-logo {
					max-width: 28rem;
					width: 100%;
					height: auto;
					margin-left: auto;
					margin-right: auto;
					display: block;
				}
				.landing-tagline {
					font-size: 1rem;
					line-height: 1.6;
					color: oklch(0.32 0.02 250);
				}
				.landing-about {
					color: oklch(0.32 0.02 250);
					line-height: 1.7;
					font-size: 0.95rem;
				}
			</style>
		</head>
		<body class="bg-base-100 min-h-screen">
			@auth.Navbar(userEmail, "", buildLabel, buildCommit)
			<main class="landing-hero">
				<div class="landing-card">
					<header class="text-center mb-6">
						<img class="landing-logo" src="/static/logo.png" alt="gogogo-fullstack-template"/>
					</header>

					<section class="landing-tagline mb-6">
						<p class="font-semibold mb-2">Built to be useful.</p>
						<p>
							Every decision favors practical outcomes over abstract ideals.
							The stack intentionally optimizes for simplicity, consistency,
							and shipping software with minimal friction.
						</p>
					</section>

					<section class="landing-about mb-8">
						<p class="mb-3">
							<strong>gogogo-fullstack-template</strong> is a full-stack Go web
							app template: back-end, front-end, database, auth, queue,
							workflow runtime, real-time layer, secrets vault, and deploy —
							all built into a single self-contained binary. PocketBase for
							data and auth, Templ for type-safe HTML, Datastar for reactive
							UI over SSE, and NATS JetStream for cross-instance real-time.
							No external services, no Docker required, no JavaScript build
							step. Browser offline support via Service Worker + Background
							Sync on the web, and a NATS Leaf Node on desktop and mobile.
						</p>
						<p>
							The code, configuration, and deploy scripts in this repo are
							literally the project — nothing is hidden behind a closed
							SDK or an opaque framework. Clone it, rename it, deploy it.
						</p>
					</section>

					<div class="text-center">
						<a href="/todo" class="btn btn-primary btn-lg">
							Access demo site
						</a>
						if userEmail == "" {
							<p class="text-sm text-base-content/60 mt-3">
								You'll be asked to sign in with the demo credentials.
							</p>
						}
					</div>
				</div>
			</main>
			@components.OfflineBanner(true)
		</body>
	</html>
}
